# ShieldScan configuration
SHIELDSCAN_HOST=0.0.0.0
SHIELDSCAN_PORT=8000
SHIELDSCAN_DATABASE_URL=sqlite:///./shieldscan.db

# OWASP ZAP (start via docker compose)
ZAP_API_URL=http://127.0.0.1:8081
ZAP_API_KEY=changeme

# Scan depth (built-in scanner)
CRAWL_MAX_PAGES=80
CRAWL_MAX_DEPTH=4
FUZZ_MAX_PARAMS=45
SCAN_SPIDER_TIMEOUT=300
SCAN_ACTIVE_TIMEOUT=600

# Scanner mode: zap | builtin (builtin works without Docker)
SCANNER_MODE=zap

# AI reporting — leave empty to use template fallback
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-20250514
